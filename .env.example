# Environment Variables Template — LinTree KPM
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ---------------------------------------------------
# Database Configuration
# Path to SQLite file (local) or connection string (remote)
# ---------------------------------------------------
DATABASE_URL=

# ---------------------------------------------------
# JWT Authentication
# Generate with: openssl rand -base64 32
# Must be a strong random secret (≥32 characters)
# ---------------------------------------------------
JWT_SECRET=

# ---------------------------------------------------
# Admin Credentials (used only during npm run db:seed)
# Change these before deploying to production
# ---------------------------------------------------
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ---------------------------------------------------
# Storage Configuration
# "local" stores uploads in public/uploads (dev only)
# Change to "s3" or another provider for production
# ---------------------------------------------------
STORAGE_PROVIDER=local

# ---------------------------------------------------
# Base URL (optional, used for sitemap & OG metadata)
# Example: https://yourdomain.com
# ---------------------------------------------------
NEXT_PUBLIC_BASE_URL=
